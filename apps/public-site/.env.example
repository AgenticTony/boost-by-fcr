# ─── CMS ─────────────────────────────────────────────
# Set to "true" to use Hygraph CMS, omit or "false" for mock data
VITE_USE_HYGRAPH=true

# Hygraph Content API (CDN) endpoint
VITE_HYGRAPH_ENDPOINT=https://eu-west-2.cdn.hygraph.com/content/cmq1xlnd2022t07w9jmsfkk5o/master

# Hygraph Permanent Auth Token (only needed for draft/private content)
VITE_HYGRAPH_TOKEN=

